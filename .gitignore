# ==============================================================================
# Projeto BD Polifarmácia — .gitignore
# ==============================================================================

# --- Dados (CSVs grandes, não versionados) ---
data/*.csv
data/*.tsv
data/*.gz
!data/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
venv/
.venv/
env/

# --- Ambiente e secrets ---
.env
.env.*
*.env
# ... mas versiona os modelos de exemplo
!.env.example

# --- Dumps de banco ---
*.dump
*.sql.gz
*.bak

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Neo4j import ---
neo4j_import/

# --- Logs ---
*.log
logs/

# --- Jupyter & Visualização ---
.ipynb_checkpoints/
demo_grafos.html
notebooks/*.html
lib/

# --- Streamlit ---
.streamlit/secrets.toml

# --- Testes e Cobertura ---
.pytest_cache/
.coverage
htmlcov/
