# ==============================================================================
# Projeto BD Polifarmácia — Modelo de variáveis de ambiente
# ==============================================================================
# Copie este arquivo para `.env` na RAIZ do projeto e preencha com as
# credenciais reais das instâncias na GCP:
#
#     cp .env.example .env
#
# O `.env` é lido tanto pelos ETLs (etl/) quanto pela app Streamlit (app/).
# NÃO faça commit do `.env` real (já está no .gitignore).
# ==============================================================================

# ─── PostgreSQL (GCP Cloud SQL) ───────────────────────────────────────────────
PG_HOST=SEU_IP_OU_HOST_GCP
PG_PORT=5432
PG_DBNAME=polifarmacia
PG_USER=postgres
PG_PASSWORD=COLOQUE_A_SENHA_AQUI
# Cloud SQL normalmente exige SSL. Use: disable | prefer | require | verify-full
PG_SSLMODE=require

# ─── Neo4j (GCP — VM, Aura ou container) ──────────────────────────────────────
# Para conexões TLS use o esquema neo4j+s:// (ex.: Aura) ou bolt+s://
NEO4J_URI=neo4j+s://SEU_HOST_GCP:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=COLOQUE_A_SENHA_AQUI
NEO4J_DATABASE=neo4j
